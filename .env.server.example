GOOGLE_DRIVE_SERVER_PORT=8787
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/path/to/service-account.json

# Template IDs — the server reads GOOGLE_STRATEGY_WORKING_TEMPLATE_ID first,
# falling back to GOOGLE_STRATEGY_TEMPLATE_ID for backwards compatibility.
# These are the "working copies" that get modified and then restored.
GOOGLE_STRATEGY_WORKING_TEMPLATE_ID=
GOOGLE_STRATEGY_TEMPLATE_ID=
GOOGLE_STRATEGY_NO_WEBSITE_TEMPLATE_ID=

# Google Drive folder where exported PDFs will be uploaded (leave blank to skip Drive upload)
GOOGLE_STRATEGY_OUTPUT_FOLDER_ID=

# Local directory where exported PDFs are saved
GOOGLE_STRATEGY_LOCAL_OUTPUT_DIR=/path/to/Downloads

# SE Ranking API
SE_RANKING_API_KEY=
SE_RANKING_BASE_URL=https://api.seranking.com
